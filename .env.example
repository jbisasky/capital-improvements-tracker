# Copy this file to `.env` and fill in values for local development:
#
#   cp .env.example .env
#
# Vite loads `.env` automatically when you run `npm run dev` or `npm run build`.
# See docs/google-cloud-setup.md for one-time Google Cloud Console setup.
#
# Only variables prefixed with VITE_ are exposed to the browser bundle.

# --- Google OAuth (required for live sign-in + Drive storage) ---
# OAuth 2.0 Web Client ID from Google Cloud Console → APIs & Services → Credentials.
# Public identifier (safe in the bundle); still keep real values in `.env`, not in git.
# Leave empty to run demo-only — "Sign in with Google" will no-op gracefully.
VITE_GOOGLE_CLIENT_ID=

# --- OpenTelemetry / Honeycomb (optional) ---
# Ingest-only API key. If unset, telemetry silently no-ops (default for local dev).
VITE_HONEYCOMB_API_KEY=

# Trace sampling rate 0.0–1.0 (default 0.1 = 10% in production).
VITE_OTEL_SAMPLE_RATE=0.1

# Service version stamped on exported spans (default "dev" when unset).
VITE_APP_VERSION=dev
